{
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "docs:install": "pnpm install --frozen-lockfile",
    "docs:check": "pnpm -C docs-site check",
    "docs:build": "pnpm -C docs-site build",
    "docs:verify": "pnpm docs:check && pnpm docs:build",
    "docs:dev": "pnpm -C docs-site dev",
    "docs:preview": "pnpm -C docs-site preview"
  }
}
